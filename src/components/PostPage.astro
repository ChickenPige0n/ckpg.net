---
import type { CollectionEntry } from "astro:content";
import type { PostData } from "@utils/content-utils";
import { getPostUrlBySlug } from "@utils/url-utils";
import PostCard from "./PostCard.astro";

const { page } = Astro.props;

let delay = 0;
const interval = 50;
---
<div class="transition flex flex-col rounded-(--radius-large) bg-(--card-bg) py-1 md:py-0 md:bg-transparent md:gap-4 mb-4">
    {page.data.map((entry: CollectionEntry<"posts">) => (
        <PostCard
                entry={entry}
                title={(entry.data as PostData).title}
                tags={(entry.data as PostData).tags}
                category={(entry.data as PostData).category}
                published={(entry.data as PostData).published}
                updated={(entry.data as PostData).updated}
                url={getPostUrlBySlug(entry.id)}
                image={(entry.data as PostData).image}
                description={(entry.data as PostData).description}
                draft={(entry.data as PostData).draft}
                class:list="onload-animation"
                style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
        ></PostCard>
    ))}
</div>